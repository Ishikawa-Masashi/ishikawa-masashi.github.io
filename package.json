{
  "name": "@ishikawa_masashi/react-menu-bar",
  "version": "1.1.2",
  "main": "./dist/index.es.js",
  "types": "./types/index.d.ts",
  "description": "Add menu bar to your react component",
  "keywords": [
    "react",
    "react-component",
    "manu-bar"
  ],
  "scripts": {
    "dev": "vite",
    "build:vite": "tsc && vite build",
    "start": "webpack serve --config ./webpack.config.dev.js",
    "test": "cross-env NODE_ENV=test jest --verbose",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage && cat ./coverage/lcov.info | coveralls",
    "prettier": "prettier --parser typescript --single-quote --write \"src/**/*.{ts,tsx}\"",
    "prebuild": "npm run prettier && npm run test",
    "build": "npm run build:es && npm run build:umd && npm run style",
    "build:es": "npm run clean:es && cross-env NODE_ENV=production tsc",
    "build:umd": "npm run clean:umd && cross-env NODE_ENV=production webpack --config ./webpack.config.js",
    "clean:es": "rimraf lib/*",
    "clean:umd": "rimraf dist/*",
    "sass": "node-sass scss/main.scss dist/ReactMenuBar.css",
    "postsass": "postcss dist/ReactMenuBar.css --use autoprefixer -m -o dist/ReactMenuBar.css",
    "style": "npm run sass && cssnano dist/ReactMenuBar.css dist/ReactMenuBar.min.css --no-zindex --no-reduceIdents"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IshikawaMasashi/react-contexify.git"
  },
  "author": "Ishikawa Masashi <ishikawa_masashi@hotmail.com> (https://github.com/IshikawaMasashi)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/IshikawaMasashi/issues"
  },
  "devDependencies": {
    "@emotion/react": "^11.7.1",
    "@emotion/styled": "^11.6.0",
    "@ishikawa-masashi/react-katex": "^0.0.6",
    "@mui/icons-material": "^5.2.5",
    "@mui/material": "^5.2.7",
    "@types/classnames": "^2.3.1",
    "@types/enzyme": "^3.10.11",
    "@types/enzyme-adapter-react-16": "^1.0.6",
    "@types/jest": "^27.4.0",
    "@types/prop-types": "^15.7.4",
    "@types/react": "^17.0.38",
    "@types/react-dom": "^17.0.11",
    "@typescript-eslint/eslint-plugin": "^5.9.0",
    "@typescript-eslint/parser": "^5.9.0",
    "autoprefixer": "^10.4.1",
    "coveralls": "^3.1.1",
    "cross-env": "^7.0.3",
    "css-loader": "^6.5.1",
    "cssnano": "^5.0.14",
    "cssnano-cli": "^1.0.5",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.6",
    "enzyme-to-json": "^3.6.2",
    "eslint": "^8.6.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^27.4.7",
    "jest-cli": "^27.4.7",
    "node-sass": "^7.0.1",
    "postcss": "^8.4.5",
    "postcss-cli": "^9.1.0",
    "prettier": "^2.5.1",
    "raf": "^3.4.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.2.1",
    "react-test-renderer": "^17.0.2",
    "regenerator-runtime": "^0.13.9",
    "rimraf": "^3.0.2",
    "sass": "^1.46.0",
    "sass-loader": "^12.4.0",
    "style-loader": "^3.3.1",
    "ts-jest": "^27.1.2",
    "ts-loader": "^9.2.6",
    "typescript": "^4.5.4",
    "vite": "^2.7.10",
    "webpack": "^5.65.0",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.7.2"
  },
  "peerDependencies": {
    "react": ">=17.0.1",
    "react-dom": ">=17.0.1"
  },
  "dependencies": {
    "classnames": "^2.3.1"
  }
}
