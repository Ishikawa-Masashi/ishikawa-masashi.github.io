---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import MascotHero from "../components/MascotHero.astro";

const hobbies = [
  "プログラミング・開発",
  "競技プログラミング (AtCoder)",
  "自作キーボード",
  "マイクラ",
  "東方",
  "音ゲー (maimai)",
  "ウルトラマン",
  "仮面ライダー",
];
const langs = ["HTML/CSS", "Python", "C", "C++", "TypeScript", "JavaScript"];
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title="About — Ishikawa" description="Ishikawa の自己紹介" />
  </head>
  <body>
    <Header />
    <main class="pop-main">

      <!-- intro -->
      <section
        class="rise"
        style="display: flex; gap: 30px; flex-wrap: wrap; align-items: center; justify-content: center;"
      >
        <MascotHero size={240} />
        <div class="sticker" style="flex: 1 1 320px; min-width: 300px; padding: 26px 28px;">
          <span class="pop-eyebrow">About me</span>
          <h1 class="pop-h1" style="font-size: clamp(28px,5vw,46px); margin-top: 8px;">自己紹介</h1>
          <p style="font-weight: 700; font-size: 18px; line-height: 1.9; margin-top: 14px; margin-bottom: 0;">
            <b>Ishikawa</b> と申します。<br />
            プログラミングが好きなので、色々作ったりしています。<br />
            どうぞよろしくお願いします！
          </p>
        </div>
      </section>

      <!-- details -->
      <section
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 22px; margin-top: 30px;"
      >
        <div class="sticker rise" style="padding: 24px 26px;">
          <h2 class="pop-h2" style="font-size: 24px;">趣味</h2>
          <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px;">
            {hobbies.map((h, i) => (
              <span class="pop-tag" style={`background: ${i % 3 === 0 ? "var(--pop-peri)" : "#fff"};`}>{h}</span>
            ))}
          </div>
        </div>
        <div class="sticker rise" style="padding: 24px 26px; background: var(--pop-yellow);">
          <h2 class="pop-h2" style="font-size: 24px;">扱える言語</h2>
          <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px;">
            {langs.map((l) => (
              <span class="pop-tag" style="background: #fff;">{l}</span>
            ))}
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>
