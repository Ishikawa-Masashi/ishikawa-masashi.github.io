---
import { getCollection } from "astro:content";
import BaseHead from "../../../components/BaseHead.astro";
import Footer from "../../../components/Footer.astro";
import FormattedDate from "../../../components/FormattedDate.astro";
import Header from "../../../components/Header.astro";
import { SITE_TITLE } from "../../../consts";

export async function getStaticPaths() {
    const books = await getCollection("mathBooks");
    const articles = await getCollection("math");

    return books.map((book) => {
        const slug = book.id.replace(/\/_book$/, "");
        const posts = articles.filter((a) => a.id.split("/")[0] === slug);

        // 章ごとにグループ化。章内は section 順、章は chapter 番号順に並べる。
        const chapterMap = new Map<number, typeof posts>();
        for (const p of posts) {
            const ch = p.data.chapter;
            if (!chapterMap.has(ch)) chapterMap.set(ch, []);
            chapterMap.get(ch)!.push(p);
        }
        const chapters = [...chapterMap.entries()]
            .sort((a, b) => a[0] - b[0])
            .map(([chapter, items]) => ({
                chapter,
                title: items[0].data.chapterTitle,
                items: items.sort((a, b) => a.data.section - b.data.section),
            }));

        return {
            params: { book: slug },
            props: { book, chapters },
        };
    });
}

const { book, chapters } = Astro.props;
const { title, author, publisher, description } = book.data;
---

<!doctype html>
<html lang="ja">
    <head>
        <BaseHead
            title={`${title} — ${SITE_TITLE}`}
            description={description ?? title}
        />
    </head>
    <body>
        <Header />
        <main class="pop-main">
            <!-- book header -->
            <header class="rise" style="margin-bottom: 30px;">
                <a
                    href="/math"
                    class="pop-tag yellow"
                    style="text-decoration: none; display: inline-block; margin-bottom: 14px;"
                >
                    ← 数学（参考書一覧）へ
                </a>
                <h1 class="pop-h1"><span class="hl">{title}</span></h1>
                {
                    (author || publisher) && (
                        <p style="font-weight: 700; margin-top: 8px;">
                            {author}
                            {author && publisher && " / "}
                            {publisher}
                        </p>
                    )
                }
                {
                    description && (
                        <p style="font-weight: 600; margin-top: 8px;">
                            {description}
                        </p>
                    )
                }
            </header>

            <!-- 章ごとのセクション -->
            {
                chapters.map((ch) => (
                    <section style="margin-bottom: 40px;">
                        <h2
                            class="pop-h2 rise"
                            style="display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px;"
                        >
                            <span class="pop-tag" style="background: var(--pop-peri);">
                                第{ch.chapter}章
                            </span>
                            {ch.title && <span class="hl">{ch.title}</span>}
                        </h2>
                        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
                            {ch.items.map((post, i) => (
                                <a
                                    href={`/math/${post.id}/`}
                                    class="sticker wobble rise"
                                    style={`display: block; text-decoration: none; color: var(--pop-ink); overflow: hidden; animation-delay: ${i * 0.06}s;`}
                                >
                                    <div style="padding: 16px 20px 20px;">
                                        <span
                                            class="pop-tag yellow"
                                            style="font-size: 12px; padding: 3px 11px;"
                                        >
                                            {ch.chapter}.{post.data.section}
                                        </span>
                                        <h3 style="font-family: var(--font-pop); font-weight: 900; font-size: 21px; margin: 12px 0 6px;">
                                            {post.data.title}
                                        </h3>
                                        <p style="font-weight: 600; font-size: 14px; margin-bottom: 10px;">
                                            {post.data.description}
                                        </p>
                                        <div style="font-weight: 700; color: var(--pop-peri-deep);">
                                            <FormattedDate date={post.data.pubDate} />
                                        </div>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </section>
                ))
            }
        </main>
        <Footer />
    </body>
</html>
