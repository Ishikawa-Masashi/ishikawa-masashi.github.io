---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

const menu = [
  { label: "自己紹介", sub: "About me", href: "/about", color: "var(--pop-peri)" },
  { label: "ブログ", sub: "Diary", href: "/blog", color: "var(--pop-yellow)" },
  { label: "ものづくり", sub: "Tech", href: "/tech", color: "#8fd17a" },
  { label: "数学", sub: "Math", href: "/math", color: "#ff9ec7" },
];
const stack = ["Astro.js", "TypeScript", "JavaScript", "Tailwind CSS", "HTML", "CSS"];
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="pop-main">

      <!-- hero: full-bleed scenery -->
      <section
        class="rise"
        style="position: relative; width: 100vw; margin-left: calc(50% - 50vw); margin-top: calc(-1 * clamp(24px,5vw,56px)); overflow: hidden; border-bottom: 3px solid var(--pop-ink); min-height: clamp(320px, 46vh, 500px);"
      >
        <!-- sky -->
        <div style="position: absolute; inset: 0; background: linear-gradient(180deg, #bfe2ff 0%, #d6efff 46%, #eef9ff 70%); z-index: 0;"></div>

        <!-- sun + rays -->
        <div style="position: absolute; top: 13%; right: 9%; width: clamp(70px,9vw,120px); height: clamp(70px,9vw,120px); z-index: 0;">
          <div style="position: absolute; inset: -40%; border-radius: 50%; background: radial-gradient(circle, rgba(255,224,110,.55), transparent 62%);"></div>
          <div style="position: absolute; inset: -70%; border-radius: 50%; background: repeating-conic-gradient(rgba(255,221,90,.35) 0deg 6deg, transparent 6deg 18deg); -webkit-mask-image: radial-gradient(circle, transparent 46%, #000 50%, transparent 74%); mask-image: radial-gradient(circle, transparent 46%, #000 50%, transparent 74%);"></div>
          <div style="position: absolute; inset: 0; border-radius: 50%; background: radial-gradient(circle, #ffe97a 0%, #ffd23d 70%, #ffc107 100%); box-shadow: 0 0 26px rgba(255,210,61,.6);"></div>
        </div>

        <!-- distant mountains -->
        <div style="position: absolute; bottom: 16%; left: -6%; width: 55%; height: 44%; border-radius: 50% 50% 0 0 / 100% 100% 0 0; background: #bfe0c0; z-index: 0;"></div>
        <div style="position: absolute; bottom: 16%; left: 26%; width: 60%; height: 52%; border-radius: 50% 50% 0 0 / 100% 100% 0 0; background: #aed6b0; z-index: 0;"></div>

        <!-- cloud 1 (w=170) -->
        <div style="position: absolute; top: 16%; left: 7%; width: 170px; height: 71px; z-index: 0;">
          <div style="position: absolute; inset: 0; top: 38%; border-radius: 999px; background: #fff;"></div>
          <div style="position: absolute; left: 8%; top: 20%; width: 44%; height: 70%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; left: 34%; top: 0; width: 52%; height: 92%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; left: 60%; top: 26%; width: 38%; height: 62%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; inset: 0; top: 40%; border-radius: 999px; box-shadow: inset 0 -6px 10px rgba(150,180,220,.28);"></div>
        </div>
        <!-- cloud 2 (w=120) -->
        <div style="position: absolute; top: 30%; left: 37%; width: 120px; height: 50px; z-index: 0; opacity: .92;">
          <div style="position: absolute; inset: 0; top: 38%; border-radius: 999px; background: #fff;"></div>
          <div style="position: absolute; left: 8%; top: 20%; width: 44%; height: 70%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; left: 34%; top: 0; width: 52%; height: 92%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; left: 60%; top: 26%; width: 38%; height: 62%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; inset: 0; top: 40%; border-radius: 999px; box-shadow: inset 0 -6px 10px rgba(150,180,220,.28);"></div>
        </div>
        <!-- cloud 3 (w=96) -->
        <div style="position: absolute; top: 10%; left: 60%; width: 96px; height: 40px; z-index: 0; opacity: .85;">
          <div style="position: absolute; inset: 0; top: 38%; border-radius: 999px; background: #fff;"></div>
          <div style="position: absolute; left: 8%; top: 20%; width: 44%; height: 70%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; left: 34%; top: 0; width: 52%; height: 92%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; left: 60%; top: 26%; width: 38%; height: 62%; border-radius: 50%; background: #fff;"></div>
          <div style="position: absolute; inset: 0; top: 40%; border-radius: 999px; box-shadow: inset 0 -6px 10px rgba(150,180,220,.28);"></div>
        </div>

        <!-- birds -->
        <svg viewBox="0 0 24 10" width="24" height="10" style="position: absolute; top: 22%; left: 48%; z-index: 0;" aria-hidden="true">
          <path d="M1 8 Q6 1 12 6 Q18 1 23 8" fill="none" stroke="#3a3550" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <svg viewBox="0 0 24 10" width="18" height="8" style="position: absolute; top: 27%; left: 54%; z-index: 0;" aria-hidden="true">
          <path d="M1 8 Q6 1 12 6 Q18 1 23 8" fill="none" stroke="#3a3550" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <svg viewBox="0 0 24 10" width="16" height="7" style="position: absolute; top: 19%; left: 30%; z-index: 0;" aria-hidden="true">
          <path d="M1 8 Q6 1 12 6 Q18 1 23 8" fill="none" stroke="#3a3550" stroke-width="1.8" stroke-linecap="round" />
        </svg>

        <!-- hills -->
        <div style="position: absolute; bottom: 0; left: -8%; width: 62%; height: 62%; border-radius: 50% 50% 0 0 / 100% 100% 0 0; background: #8fd17a; z-index: 0;"></div>
        <div style="position: absolute; bottom: 0; right: -10%; width: 66%; height: 74%; border-radius: 50% 50% 0 0 / 100% 100% 0 0; background: #7ac46a; z-index: 0;"></div>
        <!-- ground -->
        <div style="position: absolute; bottom: 0; left: 0; width: 100%; height: 20%; background: linear-gradient(180deg, #6fbf5e, #57a84a); z-index: 0;"></div>

        <!-- content -->
        <div
          style="position: relative; z-index: 1; max-width: 1080px; margin: 0 auto; padding: clamp(12px,2.4vw,26px) clamp(16px,4vw,32px) 0; display: flex; flex-wrap: wrap; gap: 28px; align-items: flex-end; justify-content: center;"
        >
          <div style="flex: 1 1 340px; min-width: 300px; padding-bottom: clamp(10px,1.6vw,22px);">
            <span class="pop-eyebrow">Welcome to my website</span>
            <h1 class="pop-h1" style="margin-top: 10px;">
              こんにちは、<br /><span class="hl">Ishikawa</span> です！
            </h1>
            <p style="font-size: 19px; font-weight: 700; line-height: 1.7; max-width: 460px; margin-top: 16px; margin-bottom: 0;">
              プログラミングが好きで、ゲームや競プロ、自作キーボードで遊んでいます。色々作ったものを置いていく場所です。
            </p>
            <div style="display: flex; gap: 14px; flex-wrap: wrap; margin-top: 26px; padding-bottom: clamp(10px,1.6vw,22px);">
              <a href="/blog" class="pop-btn blue">ブログを読む →</a>
              <a href="/about" class="pop-btn white">自己紹介</a>
            </div>
          </div>
          <div style="flex: 0 0 auto; width: clamp(150px,20vw,215px); align-self: flex-end;">
            <img class="float" src="/ishikawa.svg" alt="Ishikawa mascot" style="width: 100%; display: block; filter: drop-shadow(0 8px 10px rgba(0,0,0,.22));" />
          </div>
        </div>
      </section>

      <!-- menu cards -->
      <section style="margin-top: 60px;">
        <h2 class="pop-h2">
          掲載しているもの
          <span style="font-size: 16px; font-weight: 700; color: var(--pop-peri-deep);">(予定含む)</span>
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 22px;">
          {menu.map((m, i) =>
            m.href ? (
              <a
                href={m.href}
                class="sticker wobble"
                style="text-align: left; padding: 22px; display: block; text-decoration: none; color: var(--pop-ink);"
              >
                <div style={`width: 46px; height: 46px; border-radius: 14px; border: 3px solid var(--pop-ink); background: ${m.color}; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 20px; box-shadow: var(--shadow-pop-sm);`}>
                  {String(i + 1).padStart(2, "0")}
                </div>
                <div style="font-weight: 900; font-size: 22px; margin-top: 16px;">{m.label}</div>
                <div style="font-weight: 700; color: var(--pop-peri-deep); margin-top: 2px;">{m.sub}</div>
                <div style="margin-top: 14px; font-weight: 800; color: var(--pop-blue);">ひらく →</div>
              </a>
            ) : (
              <div
                class="sticker"
                style="text-align: left; padding: 22px; opacity: 0.6; cursor: default;"
              >
                <div style={`width: 46px; height: 46px; border-radius: 14px; border: 3px solid var(--pop-ink); background: ${m.color}; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 20px; box-shadow: var(--shadow-pop-sm);`}>
                  {String(i + 1).padStart(2, "0")}
                </div>
                <div style="font-weight: 900; font-size: 22px; margin-top: 16px;">{m.label}</div>
                <div style="font-weight: 700; color: var(--pop-peri-deep); margin-top: 2px;">{m.sub}</div>
              </div>
            )
          )}
        </div>
      </section>

      <!-- tech stack -->
      <section style="margin-top: 56px;">
        <div class="sticker" style="padding: 26px 28px; background: var(--pop-peri);">
          <h2 class="pop-h2">このページの技術スタック</h2>
          <div style="display: flex; flex-wrap: wrap; gap: 12px; margin-top: 18px;">
            {stack.map((t, i) => (
              <span
                class="pop-tag"
                style={`background: #fff; transform: rotate(${(i % 2 ? 1 : -1) * (1 + (i % 3))}deg);`}
              >
                {t}
              </span>
            ))}
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>
