---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"];
const { title, description, pubDate, updatedDate, heroImage } = Astro.props;

const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean); // 例: ["math", "book-slug", "article"]

let backHref: string;
let backLabel: string;
let tag: string;

if (pathname.startsWith("/math")) {
  // 数学記事は所属する参考書ページへ戻す
  backHref = `/math/${segments[1]}`;
  backLabel = "← 参考書へ戻る";
  tag = "数学";
} else if (pathname.startsWith("/tech")) {
  backHref = "/tech";
  backLabel = "← プログラミングへ戻る";
  tag = "Tech";
} else {
  backHref = "/blog";
  backLabel = "← ブログへ戻る";
  tag = "日記";
}
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main class="pop-main">
      <article class="sticker rise" style="max-width: 760px; margin: 0 auto; overflow: hidden;">

        <!-- article header -->
        <div
          style="background: var(--pop-peri); border-bottom: 3px solid var(--pop-ink); padding: 30px; text-align: center;"
        >
          <span class="pop-tag yellow">{tag}</span>
          <h1 class="pop-h1" style="font-size: clamp(28px,5vw,44px); margin-top: 14px;">{title}</h1>
          <div style="font-weight: 800; margin-top: 8px;">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span style="font-style: italic; font-weight: 700; font-size: 14px; margin-left: 8px;">
                (更新: <FormattedDate date={updatedDate} />)
              </span>
            )}
          </div>
          {heroImage && (
            <div style="margin-top: 22px; display: flex; justify-content: center;">
              <div
                style="background: #fff; border: 3px solid var(--pop-ink); border-radius: 20px; padding: 14px; box-shadow: var(--shadow-pop);"
              >
                <img
                  src={heroImage}
                  alt=""
                  style="max-width: 280px; max-height: 180px; object-fit: contain; display: block;"
                />
              </div>
            </div>
          )}
        </div>

        <!-- article body -->
        <div style="padding: 28px clamp(22px,5vw,44px) 40px; font-weight: 600; font-size: 18px; line-height: 1.9;">
          <slot />
          <div style="margin-top: 32px;">
            <a href={backHref} class="pop-btn peri">{backLabel}</a>
          </div>
        </div>

      </article>
    </main>
    <Footer />
  </body>
</html>
