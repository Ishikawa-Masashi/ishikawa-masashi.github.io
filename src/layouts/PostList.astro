---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

interface Props {
  posts: CollectionEntry<"blog" | "tech" | "math">[];
  basePath: string;
}

const { posts, basePath } = Astro.props;

const meta: Record<string, { title: string; sub: string; tag: string }> = {
  blog: { title: "ブログ", sub: "Diary", tag: "日記" },
  tech: { title: "プログラミング", sub: "Tech notes", tag: "Tech" },
  math: { title: "数学", sub: "Math", tag: "数学" },
};
const { title, sub, tag } = meta[basePath] ?? { title: basePath, sub: "", tag: basePath };
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={`${title} — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="pop-main">

      <!-- page header -->
      <header
        class="rise"
        style="display: flex; align-items: center; gap: 18px; flex-wrap: wrap; margin-bottom: 34px;"
      >
        <img src="/ishikawa.svg" alt="" class="float" style="width: 76px; height: 76px;" />
        <div>
          <span class="pop-eyebrow">{sub}</span>
          <h1 class="pop-h1"><span class="hl">{title}</span></h1>
        </div>
      </header>

      <!-- cards -->
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
        {posts.map((post, i) => (
          <a
            href={`/${basePath}/${post.id}/`}
            class="sticker wobble rise"
            style={`display: block; text-decoration: none; color: var(--pop-ink); overflow: hidden; animation-delay: ${i * 0.06}s;`}
          >
            <div
              style="background: var(--pop-peri); border-bottom: 3px solid var(--pop-ink); padding: 18px; display: flex; align-items: center; justify-content: center; height: 150px;"
            >
              {post.data.heroImage && (
                <img
                  src={post.data.heroImage}
                  alt=""
                  style="max-width: 100%; max-height: 100%; object-fit: contain; filter: drop-shadow(2px 3px 0 rgba(21,19,31,.25));"
                />
              )}
            </div>
            <div style="padding: 16px 20px 20px;">
              <span class="pop-tag yellow" style="font-size: 12px; padding: 3px 11px;">{tag}</span>
              <h3 style="font-family: var(--font-pop); font-weight: 900; font-size: 21px; margin: 12px 0 6px;">
                {post.data.title}
              </h3>
              <div style="font-weight: 700; color: var(--pop-peri-deep);">
                <FormattedDate date={post.data.pubDate} />
              </div>
            </div>
          </a>
        ))}
      </div>

    </main>
    <Footer />
  </body>
</html>
