---
const today = new Date();
---

<footer style="border-top: 3px solid var(--pop-ink); background: var(--pop-peri); margin-top: 40px;">
  <div
    class="pop-main"
    style="padding-top: 28px; padding-bottom: 28px; display: flex; flex-wrap: wrap; gap: 20px; align-items: center;"
  >
    <div style="display: flex; align-items: center; gap: 14px;">
      <img src="/ishikawa.svg" alt="" style="width: 44px; height: 44px;" />
      <div style="font-weight: 800; line-height: 1.5;">
        © {today.getFullYear()} Made by Ishikawa<br />
        <span style="font-weight: 700; font-size: 13px; opacity: .7;">All rights reserved.</span>
      </div>
    </div>
  </div>
</footer>
